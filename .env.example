# Django
DEBUG=True
SECRET_KEY=change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://user:password@db:5432/chess_academy

# Redis (for caching, sessions, rate limiting)
REDIS_URL=redis://redis:6379/0

# Email (Resend or SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_xxxxxxxx
DEFAULT_FROM_EMAIL=bookings@themovingtrain.org

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Supabase (used for data migration from existing project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# reCAPTCHA
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Google Tags / Ads (leave blank to disable)
GOOGLE_TAG_MANAGER_ID=
GOOGLE_ANALYTICS_ID=
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_CONVERSION_LABEL=

# SEO / Domain
SITE_DOMAIN=themovingtrain.org
SITE_DEFAULT_IMAGE=static/images/others/logo.svg

# Production Gunicorn tuning
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_KEEP_ALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# Logging
LOG_LEVEL=INFO
